name = "burnbox"
main = "src/worker/index.ts"
compatibility_date = "2024-12-01"

[assets]
directory = "./public"
binding = "ASSETS"
not_found_handling = "single-page-application"

[[d1_databases]]
binding = "DB"
database_name = "burnbox-db"
database_id = "<run: npx wrangler d1 create burnbox-db>"

[[kv_namespaces]]
binding = "NOTES_KV"
id = "<run: npx wrangler kv namespace create NOTES_KV>"

[[r2_buckets]]
binding = "BUCKET"
bucket_name = "burnbox-notes"

[triggers]
crons = ["0 * * * *"]
